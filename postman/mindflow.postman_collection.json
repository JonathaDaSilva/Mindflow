      "name": "Auth",
      "item": [
        {
          "name": "Registrar Psicólogo",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const res = pm.response.json();",
            "pm.collectionVariables.set('tokenPsicologo', res.token);",
            "pm.collectionVariables.set('token', res.token);",
            "pm.collectionVariables.set('psicologoUsuarioId', res.userId);",
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Token retornado', () => pm.expect(res.token).to.be.a('string'));",
            "pm.test('Perfil é PSICOLOGO', () => pm.expect(res.perfil).to.eql('PSICOLOGO'));"
          ]}}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Dra. Ana Lima\",\n  \"email\": \"ana@email.com\",\n  \"senha\": \"123456\",\n  \"perfil\": \"PSICOLOGO\",\n  \"dadosPsicologo\": {\n    \"crp\": \"06/12345\",\n    \"especialidade\": \"Ansiedade e Depressão\",\n    \"bio\": \"10 anos de experiência em saúde mental\",\n    \"regimeTrabalho\": \"HIBRIDO\",\n    \"duracaoSessaoMin\": 50,\n    \"valorSessao\": 180.00,\n    \"aceitaEmergencia\": true,\n    \"endereco\": {\n      \"logradouro\": \"Rua das Flores\",\n      \"numero\": \"123\",\n      \"bairro\": \"Centro\",\n      \"cidade\": \"Belo Horizonte\",\n      \"estado\": \"MG\",\n      \"cep\": \"30130-110\"\n    }\n  }\n}" },
            "url": { "raw": "{{baseUrl}}/auth/registrar", "host": ["{{baseUrl}}"], "path": ["auth","registrar"] }
          },
          "response": []
        },
        {
          "name": "Registrar Paciente",
