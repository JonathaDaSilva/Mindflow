{
  "info": {
    "_postman_id": "e94ca80a-0946-4740-b8f7-9acdcceebd6f",
    "name": "MindFlow API",
    "description": "Coleção completa e corrigida do MindFlow.\n\nORDEM DE EXECUÇÃO:\n1. Auth → Registrar Psicólogo  (salva token + psicologoUsuarioId)\n2. Auth → Registrar Paciente   (salva token + pacienteUsuarioId)\n3. Auth → Login Psicólogo      (troca token para o psicólogo)\n4. Disponibilidade → PUT       (psicólogo cadastra agenda)\n5. Disponibilidade → GET slots (qualquer token, use psicologoUsuarioId na URL)\n6. Auth → Login Paciente       (troca token para o paciente)\n7. Consulta → POST             (paciente agenda)\n8. Auth → Login Psicólogo      (troca token)\n9. Consulta → GET pendentes    (psicólogo vê solicitações)\n10. Consulta → PATCH status    (psicólogo confirma)\n11. Consulta → PATCH cancelar  (testa regra 24h)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",            "value": "http://localhost:8080", "type": "string" },
    { "key": "token",              "value": "", "type": "string" },
    { "key": "tokenPsicologo",     "value": "", "type": "string" },
    { "key": "tokenPaciente",      "value": "", "type": "string" },
    { "key": "psicologoUsuarioId", "value": "", "type": "string" },
    { "key": "pacienteUsuarioId",  "value": "", "type": "string" },
    { "key": "consultaId",         "value": "", "type": "string" }
  ],
